{
  "name": "libra-publish-worker",
  "version": "0.17.31",
  "private": true,
  "description": "Libra publish — Cloudflare Worker (Next.js + OpenNext) reading D1/R2 publish snapshots",
  "scripts": {
    "dev": "next dev",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "pnpm cf-typegen && opennextjs-cloudflare build",
    "preview": "pnpm cf-typegen && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "pnpm cf-typegen && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.10.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "next": "^16.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.9.0",
    "@cloudflare/workers-types": "^4.20251108.0",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.45.0"
  },
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20.11"
  }
}
