{
  "schemaVersion": 1,
  "matrix": "code_ui_remote_generation",
  "defaults": {
    "fixture": {
      "path": "tests/data/code_ui_remote/provider_fixtures/code_generation_apply_patch.json"
    },
    "options": {
      "control": "write",
      "browserControl": "off",
      "context": "dev",
      "approvalPolicy": "never"
    }
  },
  "cases": [
    {
      "name": "generation_code_service_creates_complete_rust_file_and_tests_pass",
      "priority": "P0",
      "steps": [
        {
          "name": "attach automation",
          "op": "attach",
          "kind": "automation",
          "clientId": "generation-rust-file",
          "auth": "valid_control",
          "expect": {
            "status": 200,
            "saveToken": "current"
          }
        },
        {
          "name": "call Code service with complete generation prompt",
          "op": "submitAndWaitIdle",
          "text": "/run generate-code-greeting: create a complete Rust source file named generated_greeting.rs with a public greeting function and self-contained unit tests",
          "token": "current",
          "auth": "valid_control",
          "expect": {
            "status": 200,
            "assertions": [
              "snapshot_status_idle",
              "transcript_contains:Generated generated_greeting.rs"
            ]
          }
        },
        {
          "name": "generated file exists",
          "op": "readRepoFile",
          "path": "generated_greeting.rs",
          "expect": {
            "assertions": [
              "file_contains:pub fn greeting",
              "file_contains:fn formats_name",
              "file_contains:hello, {name}"
            ]
          }
        },
        {
          "name": "generated code tests pass",
          "op": "runRepoCommand",
          "command": [
            "sh",
            "-c",
            "rustc --test generated_greeting.rs -o generated_greeting_test && ./generated_greeting_test"
          ],
          "timeoutMs": 10000,
          "expect": {
            "status": 0,
            "assertions": [
              "stdout_or_stderr_contains:test result: ok"
            ]
          }
        }
      ]
    },
    {
      "name": "generation_sse_observes_tool_execution_and_final_completion",
      "priority": "P1",
      "steps": [
        {
          "name": "attach automation",
          "op": "attach",
          "kind": "automation",
          "clientId": "generation-sse",
          "auth": "valid_control",
          "expect": {
            "status": 200,
            "saveToken": "current"
          }
        },
        {
          "name": "open stream",
          "op": "openEvents",
          "stream": "events",
          "timeoutMs": 5000
        },
        {
          "name": "call Code service",
          "op": "submit",
          "text": "/run generate-code-greeting: create a complete Rust source file named generated_greeting.rs with a public greeting function and self-contained unit tests",
          "token": "current",
          "auth": "valid_control",
          "expect": {
            "status": 200
          }
        },
        {
          "name": "observe tool or session update",
          "op": "collectEventsUntil",
          "stream": "events",
          "event": "session_updated",
          "timeoutMs": 10000,
          "expect": {
            "assertions": [
              "event_transcript_contains:Generated generated_greeting.rs"
            ]
          }
        },
        {
          "name": "generated file exists",
          "op": "readRepoFile",
          "path": "generated_greeting.rs",
          "expect": {
            "assertions": [
              "file_contains:pub fn greeting"
            ]
          }
        }
      ]
    },
    {
      "name": "generation_invalid_patch_surfaces_error_without_partial_file",
      "priority": "P1",
      "fixture": {
        "path": "tests/data/code_ui_remote/provider_fixtures/code_generation_invalid_patch.json"
      },
      "steps": [
        {
          "name": "attach automation",
          "op": "attach",
          "kind": "automation",
          "clientId": "generation-invalid-patch",
          "auth": "valid_control",
          "expect": {
            "status": 200,
            "saveToken": "current"
          }
        },
        {
          "name": "call Code service with invalid generated patch",
          "op": "submitAndWaitTerminal",
          "text": "/run generate-code-invalid-patch",
          "token": "current",
          "auth": "valid_control",
          "expect": {
            "status": 200,
            "assertions": [
              "snapshot_status_error_or_idle",
              "transcript_contains_any:invalid patch|Tool 'apply_patch' failed|Agent turn failed"
            ]
          }
        },
        {
          "name": "no partial generated file",
          "op": "repoFileAbsent",
          "path": "broken_generated.rs"
        }
      ]
    }
  ]
}
