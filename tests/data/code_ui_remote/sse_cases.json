{
  "schemaVersion": 1,
  "matrix": "code_ui_remote_sse",
  "defaults": {
    "fixture": {
      "path": "tests/fixtures/code_ui/basic_chat.json"
    },
    "options": {
      "control": "write",
      "browserControl": "off"
    }
  },
  "cases": [
    {
      "name": "sse_initial_connect_replays_session_updated_with_full_snapshot",
      "priority": "P0",
      "steps": [
        {
          "name": "open stream",
          "op": "openEvents",
          "stream": "events",
          "timeoutMs": 5000
        },
        {
          "name": "first event is initial snapshot",
          "op": "expectEvent",
          "stream": "events",
          "event": "session_updated",
          "expect": {
            "assertions": [
              "event_data_has_transcript_array",
              "event_data_has_controller"
            ]
          }
        }
      ]
    },
    {
      "name": "sse_emits_status_changed_when_submit_starts_thinking",
      "priority": "P0",
      "steps": [
        {
          "name": "attach automation",
          "op": "attach",
          "kind": "automation",
          "clientId": "sse-thinking",
          "auth": "valid_control",
          "expect": {
            "status": 200,
            "saveToken": "current"
          }
        },
        {
          "name": "open stream",
          "op": "openEvents",
          "stream": "events",
          "timeoutMs": 5000
        },
        {
          "name": "submit",
          "op": "submit",
          "text": "/chat hello",
          "token": "current",
          "auth": "valid_control",
          "expect": {
            "status": 200
          }
        },
        {
          "name": "status changed to thinking",
          "op": "collectEventsUntil",
          "stream": "events",
          "event": "status_changed",
          "timeoutMs": 5000,
          "expect": {
            "assertions": [
              "event_data_status_thinking"
            ]
          }
        }
      ]
    },
    {
      "name": "sse_emits_session_updated_after_assistant_completion",
      "priority": "P0",
      "steps": [
        {
          "name": "attach automation",
          "op": "attach",
          "kind": "automation",
          "clientId": "sse-complete",
          "auth": "valid_control",
          "expect": {
            "status": 200,
            "saveToken": "current"
          }
        },
        {
          "name": "open stream",
          "op": "openEvents",
          "stream": "events",
          "timeoutMs": 5000
        },
        {
          "name": "submit",
          "op": "submit",
          "text": "/chat hello",
          "token": "current",
          "auth": "valid_control",
          "expect": {
            "status": 200
          }
        },
        {
          "name": "completion event",
          "op": "collectEventsUntil",
          "stream": "events",
          "event": "session_updated",
          "timeoutMs": 10000,
          "expect": {
            "assertions": [
              "event_transcript_contains:fake assistant: hello from the PTY harness"
            ]
          }
        }
      ]
    },
    {
      "name": "sse_emits_controller_changed_on_attach_and_detach",
      "priority": "P0",
      "steps": [
        {
          "name": "open stream",
          "op": "openEvents",
          "stream": "events",
          "timeoutMs": 5000
        },
        {
          "name": "attach automation",
          "op": "attach",
          "kind": "automation",
          "clientId": "sse-controller",
          "auth": "valid_control",
          "expect": {
            "status": 200,
            "saveToken": "current"
          }
        },
        {
          "name": "controller changed to automation",
          "op": "collectEventsUntil",
          "stream": "events",
          "event": "controller_changed",
          "timeoutMs": 5000,
          "expect": {
            "assertions": [
              "event_data_controller_kind_automation"
            ]
          }
        },
        {
          "name": "detach automation",
          "op": "detach",
          "clientId": "sse-controller",
          "token": "current",
          "auth": "valid_control",
          "expect": {
            "status": 200
          }
        },
        {
          "name": "controller changed away from automation",
          "op": "collectEventsUntil",
          "stream": "events",
          "event": "controller_changed",
          "timeoutMs": 5000,
          "expect": {
            "assertions": [
              "event_data_controller_kind_tui_or_none"
            ]
          }
        }
      ]
    },
    {
      "name": "sse_two_concurrent_subscribers_receive_status_changed",
      "priority": "P1",
      "steps": [
        {
          "name": "attach automation",
          "op": "attach",
          "kind": "automation",
          "clientId": "sse-two-subscribers",
          "auth": "valid_control",
          "expect": {
            "status": 200,
            "saveToken": "current"
          }
        },
        {
          "name": "open stream A",
          "op": "openEvents",
          "stream": "a",
          "timeoutMs": 5000
        },
        {
          "name": "open stream B",
          "op": "openEvents",
          "stream": "b",
          "timeoutMs": 5000
        },
        {
          "name": "submit",
          "op": "submit",
          "text": "/chat hello",
          "token": "current",
          "auth": "valid_control",
          "expect": {
            "status": 200
          }
        },
        {
          "name": "stream A sees thinking",
          "op": "collectEventsUntil",
          "stream": "a",
          "event": "status_changed",
          "timeoutMs": 5000,
          "expect": {
            "assertions": [
              "event_data_status_thinking"
            ]
          }
        },
        {
          "name": "stream B sees thinking",
          "op": "collectEventsUntil",
          "stream": "b",
          "event": "status_changed",
          "timeoutMs": 5000,
          "expect": {
            "assertions": [
              "event_data_status_thinking"
            ]
          }
        }
      ]
    },
    {
      "name": "sse_reconnect_initial_replay_contains_latest_transcript",
      "priority": "P1",
      "steps": [
        {
          "name": "attach automation",
          "op": "attach",
          "kind": "automation",
          "clientId": "sse-reconnect",
          "auth": "valid_control",
          "expect": {
            "status": 200,
            "saveToken": "current"
          }
        },
        {
          "name": "open and close stream",
          "op": "openEvents",
          "stream": "old",
          "timeoutMs": 5000,
          "closeImmediately": true
        },
        {
          "name": "submit while disconnected",
          "op": "submitAndWaitIdle",
          "text": "/chat hello",
          "token": "current",
          "auth": "valid_control",
          "expect": {
            "status": 200
          }
        },
        {
          "name": "reopen stream",
          "op": "openEvents",
          "stream": "new",
          "timeoutMs": 5000
        },
        {
          "name": "initial replay has completed transcript",
          "op": "expectEvent",
          "stream": "new",
          "event": "session_updated",
          "expect": {
            "assertions": [
              "event_transcript_contains:fake assistant: hello from the PTY harness"
            ]
          }
        }
      ]
    },
    {
      "name": "sse_streaming_fixture_transcript_content_grows_monotonically",
      "priority": "P1",
      "fixture": {
        "path": "tests/data/code_ui_remote/provider_fixtures/streaming_chat.json"
      },
      "steps": [
        {
          "name": "attach automation",
          "op": "attach",
          "kind": "automation",
          "clientId": "sse-streaming",
          "auth": "valid_control",
          "expect": {
            "status": 200,
            "saveToken": "current"
          }
        },
        {
          "name": "open stream",
          "op": "openEvents",
          "stream": "events",
          "timeoutMs": 5000
        },
        {
          "name": "submit streamed prompt",
          "op": "submit",
          "text": "/chat stream",
          "token": "current",
          "auth": "valid_control",
          "expect": {
            "status": 200
          }
        },
        {
          "name": "collect monotonic transcript events",
          "op": "collectSessionUpdates",
          "stream": "events",
          "timeoutMs": 10000,
          "expect": {
            "assertions": [
              "assistant_content_monotonic",
              "event_transcript_contains:fake assistant: streamed response"
            ]
          }
        }
      ]
    }
  ]
}
