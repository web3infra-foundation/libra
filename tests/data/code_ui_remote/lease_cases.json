{
  "schemaVersion": 1,
  "matrix": "code_ui_remote_lease",
  "defaults": {
    "fixture": {
      "path": "tests/fixtures/code_ui/basic_chat.json"
    },
    "options": {
      "control": "write",
      "browserControl": "off",
      "leaseDurationMs": null
    }
  },
  "cases": [
    {
      "name": "lease_attach_automation_succeeds_with_control_token",
      "priority": "P0",
      "steps": [
        {
          "name": "attach automation",
          "op": "attach",
          "kind": "automation",
          "clientId": "lease-automation-ok",
          "auth": "valid_control",
          "expect": {
            "status": 200,
            "saveToken": "current",
            "assertions": [
              "controller_token_non_empty",
              "lease_expires_at_future",
              "controller_kind_automation"
            ]
          }
        }
      ]
    },
    {
      "name": "lease_attach_automation_without_control_token_is_403_missing",
      "priority": "P0",
      "steps": [
        {
          "name": "attach automation without process token",
          "op": "attach",
          "kind": "automation",
          "clientId": "lease-missing-control",
          "auth": "missing_control",
          "expect": {
            "status": 403,
            "errorCode": "MISSING_CONTROL_TOKEN"
          }
        }
      ]
    },
    {
      "name": "lease_attach_automation_with_wrong_control_token_is_403_invalid",
      "priority": "P0",
      "steps": [
        {
          "name": "attach automation with wrong process token",
          "op": "attach",
          "kind": "automation",
          "clientId": "lease-invalid-control",
          "auth": "invalid_control",
          "expect": {
            "status": 403,
            "errorCode": "INVALID_CONTROL_TOKEN"
          }
        }
      ]
    },
    {
      "name": "lease_attach_invalid_kind_returns_400",
      "priority": "P0",
      "steps": [
        {
          "name": "attach invalid kind",
          "op": "attach",
          "kind": "tui",
          "clientId": "lease-invalid-kind",
          "auth": "valid_control",
          "expect": {
            "status": 400,
            "errorCode": "INVALID_CONTROLLER_KIND"
          }
        }
      ]
    },
    {
      "name": "lease_attach_renew_with_same_client_id_extends_expiry",
      "priority": "P0",
      "steps": [
        {
          "name": "first attach",
          "op": "attach",
          "kind": "automation",
          "clientId": "lease-renew",
          "auth": "valid_control",
          "expect": {
            "status": 200,
            "saveToken": "current",
            "saveLeaseExpiresAt": "first"
          }
        },
        {
          "name": "wait before renewal",
          "op": "sleep",
          "durationMs": 25
        },
        {
          "name": "renew same client",
          "op": "attach",
          "kind": "automation",
          "clientId": "lease-renew",
          "auth": "valid_control",
          "expect": {
            "status": 200,
            "saveToken": "current",
            "assertions": [
              "lease_expires_after:first"
            ]
          }
        }
      ]
    },
    {
      "name": "lease_attach_conflict_when_other_client_holds",
      "priority": "P0",
      "steps": [
        {
          "name": "client A attach",
          "op": "attach",
          "kind": "automation",
          "clientId": "lease-client-a",
          "auth": "valid_control",
          "expect": {
            "status": 200,
            "saveToken": "current"
          }
        },
        {
          "name": "client B attach",
          "op": "attach",
          "kind": "automation",
          "clientId": "lease-client-b",
          "auth": "valid_control",
          "expect": {
            "status": 409,
            "errorCode": "CONTROLLER_CONFLICT"
          }
        }
      ]
    },
    {
      "name": "lease_detach_releases_to_local_tui",
      "priority": "P0",
      "steps": [
        {
          "name": "attach automation",
          "op": "attach",
          "kind": "automation",
          "clientId": "lease-detach",
          "auth": "valid_control",
          "expect": {
            "status": 200,
            "saveToken": "current"
          }
        },
        {
          "name": "detach automation",
          "op": "detach",
          "clientId": "lease-detach",
          "token": "current",
          "auth": "valid_control",
          "expect": {
            "status": 200
          }
        },
        {
          "name": "snapshot after detach",
          "op": "waitSnapshot",
          "expect": {
            "assertions": [
              "controller_kind_tui_or_none",
              "controller_can_write_false"
            ]
          }
        }
      ]
    },
    {
      "name": "lease_detach_with_wrong_controller_token_is_rejected",
      "priority": "P0",
      "steps": [
        {
          "name": "attach automation",
          "op": "attach",
          "kind": "automation",
          "clientId": "lease-wrong-detach",
          "auth": "valid_control",
          "expect": {
            "status": 200,
            "saveToken": "current"
          }
        },
        {
          "name": "detach with forged token",
          "op": "detach",
          "clientId": "lease-wrong-detach",
          "token": "forged",
          "auth": "valid_control",
          "expect": {
            "status": 403,
            "errorCode": "INVALID_CONTROLLER_TOKEN"
          }
        },
        {
          "name": "snapshot still automation",
          "op": "waitSnapshot",
          "expect": {
            "assertions": [
              "controller_kind_automation"
            ]
          }
        }
      ]
    },
    {
      "name": "lease_expiry_releases_and_rejects_stale_token",
      "priority": "P0",
      "options": {
        "leaseDurationMs": 500
      },
      "steps": [
        {
          "name": "attach short lease",
          "op": "attach",
          "kind": "automation",
          "clientId": "lease-expire-a",
          "auth": "valid_control",
          "expect": {
            "status": 200,
            "saveToken": "stale"
          }
        },
        {
          "name": "wait past lease ttl",
          "op": "sleep",
          "durationMs": 800
        },
        {
          "name": "submit with stale token",
          "op": "submit",
          "text": "/chat hello",
          "token": "stale",
          "auth": "valid_control",
          "expect": {
            "status": 409,
            "errorCode": "CONTROLLER_CONFLICT"
          }
        },
        {
          "name": "new client can attach",
          "op": "attach",
          "kind": "automation",
          "clientId": "lease-expire-b",
          "auth": "valid_control",
          "expect": {
            "status": 200,
            "saveToken": "current"
          }
        }
      ]
    },
    {
      "name": "lease_attach_observe_mode_rejects_automation_with_control_disabled",
      "priority": "P0",
      "options": {
        "control": "observe"
      },
      "steps": [
        {
          "name": "attach automation in observe mode",
          "op": "attach",
          "kind": "automation",
          "clientId": "lease-observe-mode",
          "auth": "missing_control",
          "expect": {
            "status": 403,
            "errorCode": "CONTROL_DISABLED"
          }
        }
      ]
    }
  ]
}
