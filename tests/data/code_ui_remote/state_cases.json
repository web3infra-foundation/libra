{
  "schemaVersion": 1,
  "matrix": "code_ui_remote_state",
  "defaults": {
    "fixture": {
      "path": "tests/fixtures/code_ui/basic_chat.json"
    },
    "options": {
      "control": "write",
      "browserControl": "off"
    }
  },
  "cases": [
    {
      "name": "state_two_clients_attach_serial_ok_after_detach",
      "priority": "P1",
      "steps": [
        {
          "name": "client A attach",
          "op": "attach",
          "kind": "automation",
          "clientId": "state-serial-a",
          "auth": "valid_control",
          "expect": {
            "status": 200,
            "saveToken": "stale"
          }
        },
        {
          "name": "client A detach",
          "op": "detach",
          "clientId": "state-serial-a",
          "token": "stale",
          "auth": "valid_control",
          "expect": {
            "status": 200
          }
        },
        {
          "name": "client B attach",
          "op": "attach",
          "kind": "automation",
          "clientId": "state-serial-b",
          "auth": "valid_control",
          "expect": {
            "status": 200,
            "saveToken": "current",
            "assertions": [
              "controller_token_differs_from_stale"
            ]
          }
        }
      ]
    },
    {
      "name": "state_two_clients_attach_parallel_one_wins_one_conflict",
      "priority": "P1",
      "steps": [
        {
          "name": "parallel attach",
          "op": "parallelAttach",
          "kind": "automation",
          "clientIds": [
            "state-parallel-a",
            "state-parallel-b"
          ],
          "auth": "valid_control",
          "expect": {
            "statusesAnyOrder": [
              200,
              409
            ],
            "errorCodes": [
              null,
              "CONTROLLER_CONFLICT"
            ]
          }
        }
      ]
    },
    {
      "name": "state_submit_while_thinking_returns_session_busy",
      "priority": "P1",
      "fixture": {
        "path": "tests/fixtures/code_ui/delayed_chat.json"
      },
      "steps": [
        {
          "name": "attach automation",
          "op": "attach",
          "kind": "automation",
          "clientId": "state-busy",
          "auth": "valid_control",
          "expect": {
            "status": 200,
            "saveToken": "current"
          }
        },
        {
          "name": "submit slow turn",
          "op": "submit",
          "text": "/chat slow",
          "token": "current",
          "auth": "valid_control",
          "expect": {
            "status": 200
          }
        },
        {
          "name": "wait thinking",
          "op": "waitSnapshot",
          "expect": {
            "assertions": [
              "snapshot_status_thinking"
            ]
          }
        },
        {
          "name": "submit again while busy",
          "op": "submit",
          "text": "/chat again",
          "token": "current",
          "auth": "valid_control",
          "expect": {
            "status": 409,
            "errorCode": "SESSION_BUSY"
          }
        }
      ]
    },
    {
      "name": "state_cancel_when_idle_returns_session_busy",
      "priority": "P1",
      "steps": [
        {
          "name": "attach automation",
          "op": "attach",
          "kind": "automation",
          "clientId": "state-cancel-idle",
          "auth": "valid_control",
          "expect": {
            "status": 200,
            "saveToken": "current"
          }
        },
        {
          "name": "cancel idle",
          "op": "cancel",
          "token": "current",
          "auth": "valid_control",
          "expect": {
            "status": 409,
            "errorCode": "SESSION_BUSY"
          }
        }
      ]
    },
    {
      "name": "state_payload_at_256_kib_boundary_is_accepted",
      "priority": "P1",
      "steps": [
        {
          "name": "attach automation",
          "op": "attach",
          "kind": "automation",
          "clientId": "state-boundary-256",
          "auth": "valid_control",
          "expect": {
            "status": 200,
            "saveToken": "current"
          }
        },
        {
          "name": "submit 256 KiB text",
          "op": "submitBytes",
          "bytes": 262144,
          "token": "current",
          "auth": "valid_control",
          "expect": {
            "status": 200
          }
        }
      ]
    },
    {
      "name": "state_payload_at_257_kib_returns_413",
      "priority": "P1",
      "steps": [
        {
          "name": "attach automation",
          "op": "attach",
          "kind": "automation",
          "clientId": "state-boundary-257",
          "auth": "valid_control",
          "expect": {
            "status": 200,
            "saveToken": "current"
          }
        },
        {
          "name": "submit 257 KiB text",
          "op": "submitBytes",
          "bytes": 263168,
          "token": "current",
          "auth": "valid_control",
          "expect": {
            "status": 413,
            "errorCode": "PAYLOAD_TOO_LARGE"
          }
        }
      ]
    },
    {
      "name": "state_payload_at_drain_limit_1_mib_returns_413_without_hanging",
      "priority": "P1",
      "steps": [
        {
          "name": "attach automation",
          "op": "attach",
          "kind": "automation",
          "clientId": "state-drain-limit",
          "auth": "valid_control",
          "expect": {
            "status": 200,
            "saveToken": "current"
          }
        },
        {
          "name": "submit 1 MiB text",
          "op": "submitBytes",
          "bytes": 1048576,
          "token": "current",
          "auth": "valid_control",
          "timeoutMs": 5000,
          "expect": {
            "status": 413,
            "errorCode": "PAYLOAD_TOO_LARGE"
          }
        }
      ]
    },
    {
      "name": "state_tool_call_fixture_reaches_tool_phase_or_deferred_l1",
      "priority": "P2",
      "fixture": {
        "path": "tests/data/code_ui_remote/provider_fixtures/tool_call_chat.json"
      },
      "notes": "Use this only after the runner proves the fake tool-call fixture does not loop. If it is flaky, move the cancellation assertion to L1.",
      "steps": [
        {
          "name": "attach automation",
          "op": "attach",
          "kind": "automation",
          "clientId": "state-tool-call",
          "auth": "valid_control",
          "expect": {
            "status": 200,
            "saveToken": "current"
          }
        },
        {
          "name": "open stream",
          "op": "openEvents",
          "stream": "events",
          "timeoutMs": 5000
        },
        {
          "name": "submit tool prompt",
          "op": "submit",
          "text": "/chat tool",
          "token": "current",
          "auth": "valid_control",
          "expect": {
            "status": 200
          }
        },
        {
          "name": "observe executing tool",
          "op": "collectEventsUntil",
          "stream": "events",
          "event": "status_changed",
          "timeoutMs": 10000,
          "expect": {
            "assertions": [
              "event_data_status_executing_tool"
            ]
          }
        }
      ]
    }
  ]
}
